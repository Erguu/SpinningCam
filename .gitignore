# EMS license signing — NEVER commit the private key or generated licenses
license_private_key.pem
*.pem
*.lic

# Python
__pycache__/
*.pyc

# Build artifacts
build/
dist/
Build_exe_output.txt

# Logs & dev scratch (local only)
*.log
backup/
images/
crash_output.txt
latestchanges.txt

# Claude Code local settings
.claude/settings.local.json
ops_library.json

# Per-user runtime state — the app REWRITES this constantly (params, camera,
# sidebar width, language, license/admin flags), so tracking it makes every
# `git pull` collide with each user's local changes. Untracked: the app rebuilds
# it from code defaults (main.py load_settings) when it is absent.
settings.json

# Runtime-owned DATA (Phase 2 pull fix): the app rewrites these on tool edits /
# calibration, so tracking them collides on `git pull`. The LIVE files are ignored;
# the tracked `*.default.json` SEEDS ship instead and first_run_seed.py copies a
# seed -> live file on first launch when the live one is missing.
tools.json
machines/*.json
!machines/*.default.json
